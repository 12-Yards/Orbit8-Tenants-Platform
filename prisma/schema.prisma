  fieldId            Int     @map("field_id")
  fieldLabel         String  @map("field_label")
  value              String
  tenantId           String? @map("tenant_id") @db.VarChar

  @@map("play_request_offer_criteria")
}

model PlayRequestOffers {
  id            Int       @id @default(autoincrement())
  playRequestId Int       @map("play_request_id")
  userId        String    @map("user_id")
  note          String?
  status        String?   @default("pending")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  responseNote  String?   @map("response_note")
  clubName      String?   @map("club_name")
  tenantId      String?   @map("tenant_id") @db.VarChar

  @@map("play_request_offers")
}

model PlayRequests {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id") @db.VarChar(255)
  guests    String[]  @default([])
  startDate DateTime  @map("start_date") @db.Timestamp(6)
  startTime String?   @map("start_time")
  endDate   DateTime? @map("end_date") @db.Timestamp(6)
  endTime   String?   @map("end_time")
  message   String?
  status    String?   @default("active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId  String?   @map("tenant_id") @db.VarChar

