}

model PodcastComments {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  podcastId       String    @map("podcast_id") @db.VarChar(36)
  userId          String    @map("user_id") @db.VarChar(255)
  parentCommentId String?   @map("parent_comment_id") @db.VarChar(36)
  content         String
