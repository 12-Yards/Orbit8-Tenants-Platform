  updatedAt       DateTime? @map("updated_at") @db.Timestamp(6)
  edited          Boolean?  @default(false)
  tenantId        String?   @map("tenant_id") @db.VarChar

  @@map("podcast_comments")
}

model PodcastLikes {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  podcastId String  @map("podcast_id") @db.VarChar(36)
  userId    String  @map("user_id") @db.VarChar(255)
  tenantId  String? @map("tenant_id") @db.VarChar

  @@map("podcast_likes")
}

model Podcasts {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  title        String
  slug         String
  excerpt      String
  content      String
  heroImageUrl String?   @map("hero_image_url")
  mediaUrl     String?   @map("media_url")
  mediaType    String?   @default("link") @map("media_type")
  author       String
  publishedAt  String    @map("published_at")
  isActive     Boolean?  @default(true) @map("is_active")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId     String?   @map("tenant_id") @db.VarChar

  @@unique([slug, tenantId])
  @@map("podcasts")
}

model PollVotes {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  pollId      String    @map("poll_id") @db.VarChar(36)
  userId      String    @map("user_id") @db.VarChar(255)
  optionIndex Int       @map("option_index")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId    String?   @map("tenant_id") @db.VarChar

  @@map("poll_votes")
}

model Polls {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  title         String
  imageUrl      String    @map("image_url")
  options       Json
  startDate     DateTime  @map("start_date") @db.Timestamp(6)
  durationHours Int       @map("duration_hours")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  isActive      Boolean?  @default(true) @map("is_active")
  slug          String
  optionImages  Json?     @default("[]") @map("option_images") @db.Json
  article       String?
  boostedVotes  Int?      @default(0) @map("boosted_votes")
  pollType      String    @default("standard") @map("poll_type")
  tenantId      String?   @map("tenant_id") @db.VarChar

  @@unique([slug, tenantId])
  @@map("polls")
}

model ProfileFieldDefinitions {
  id                     Int       @id @default(autoincrement())
  label                  String
  slug                   String
