generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ArticleCategories {
  id         Int       @id @default(autoincrement())
  name       String
  icon       String?   @default("folder")
  orderIndex Int?      @default(0) @map("order_index")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId   String?   @map("tenant_id") @db.VarChar

  @@unique([name, tenantId])
  @@map("article_categories")
}

model ArticleLikes {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  articleId String  @map("article_id") @db.VarChar(36)
  userId    String  @map("user_id") @db.VarChar(255)
  tenantId  String? @map("tenant_id") @db.VarChar

  @@map("article_likes")
}

model ArticleSections {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  articleId     String  @map("article_id") @db.VarChar(36)
  orderIndex    Int     @map("order_index")
  sectionType   String  @map("section_type")
  heading       String?
  content       String?
  mediaUrls     Json?   @default("[]") @map("media_urls")
  mediaCaptions Json?   @default("[]") @map("media_captions") @db.Json
  muxPlaybackId String? @map("mux_playback_id")
  muxAssetId    String? @map("mux_asset_id")
  tenantId      String? @map("tenant_id") @db.VarChar

  @@map("article_sections")
}

model Articles {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  title        String
  slug         String
  category     String
  excerpt      String
  content      String
  heroImageUrl String  @map("hero_image_url")
  publishedAt  String  @map("published_at")
  author       String
  readingTime  Int     @map("reading_time")
  boostedLikes Int?    @default(0) @map("boosted_likes")
  imageUrls    Json?   @default("[]") @map("image_urls")
  tenantId     String? @map("tenant_id") @db.VarChar

  @@unique([slug, tenantId])
  @@map("articles")
}

model Comments {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  articleId       String    @map("article_id") @db.VarChar(36)
  userId          String    @map("user_id") @db.VarChar(255)
  content         String
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  parentCommentId String?   @map("parent_comment_id") @db.VarChar(36)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(6)
  edited          Boolean?  @default(false)
  tenantId        String?   @map("tenant_id") @db.VarChar

  @@map("comments")
}

model CompetitionBrackets {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId     String    @unique @map("event_id") @db.VarChar(36)
  totalRounds Int       @map("total_rounds")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId    String?   @map("tenant_id") @db.VarChar

  @@map("competition_brackets")
}

model CompetitionMatches {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  roundId                 String    @map("round_id") @db.VarChar(36)
  matchNumber             Int       @map("match_number")
  team1Id                 String?   @map("team1_id") @db.VarChar(36)
  team2Id                 String?   @map("team2_id") @db.VarChar(36)
  winnerId                String?   @map("winner_id") @db.VarChar(36)
  score1                  Int?
  score2                  Int?
  createdAt               DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  resultSubmittedByTeamId String?   @map("result_submitted_by_team_id") @db.VarChar(36)
  proposedWinnerId        String?   @map("proposed_winner_id") @db.VarChar(36)
  resultSubmittedByUserId String?   @map("result_submitted_by_user_id") @db.VarChar(36)
  resultConfirmedByUserId String?   @map("result_confirmed_by_user_id") @db.VarChar(36)
  resultConfirmedAt       DateTime? @map("result_confirmed_at") @db.Timestamp(6)
  tenantId                String?   @map("tenant_id") @db.VarChar

  @@map("competition_matches")
}

model CompetitionRounds {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  bracketId   String    @map("bracket_id") @db.VarChar(36)
  roundNumber Int       @map("round_number")
  roundName   String    @map("round_name")
  deadline    DateTime? @db.Timestamp(6)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId    String?   @map("tenant_id") @db.VarChar

  @@map("competition_rounds")
}

model CompetitionTeams {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId        String    @map("event_id") @db.VarChar(36)
  teamNumber     Int       @map("team_number")
  player1EntryId String?   @map("player1_entry_id") @db.VarChar(40)
  player2EntryId String?   @map("player2_entry_id") @db.VarChar(40)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  player3EntryId String?   @map("player3_entry_id") @db.VarChar(40)
  player4EntryId String?   @map("player4_entry_id") @db.VarChar(40)
  player5EntryId String?   @map("player5_entry_id") @db.VarChar(40)
  player6EntryId String?   @map("player6_entry_id") @db.VarChar(40)
  teamStableford Int?      @map("team_stableford")
  teeTime        String?   @map("tee_time") @db.VarChar(10)
  teamHandicap   Int?      @map("team_handicap")
  tenantId       String?   @map("tenant_id") @db.VarChar

  @@map("competition_teams")
}

model ConnectionNotifications {
  id            Int       @id @default(autoincrement())
  userId        String    @map("user_id") @db.VarChar(255)
  type          String
  connectionId  Int?      @map("connection_id")
  isRead        Boolean?  @default(false) @map("is_read")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  messageId     Int?      @map("message_id")
  fromUserId    String?   @map("from_user_id") @db.VarChar(255)
  eventId       String?   @map("event_id") @db.VarChar(255)
  teamId        String?   @map("team_id") @db.VarChar(255)
  matchId       String?   @map("match_id") @db.VarChar(255)
  metadata      String?
  playRequestId Int?      @map("play_request_id")
  tenantId      String?   @map("tenant_id") @db.VarChar

  @@map("connection_notifications")
}

model ContactRequests {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  name      String
  email     String
  phone     String?
  message   String
  type      String    @default("Contact Form")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  isRead    Boolean?  @default(false) @map("is_read")
  tenantId  String?   @map("tenant_id") @db.VarChar

  @@map("contact_requests")
}

model EventAttendees {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId      String    @map("event_id") @db.VarChar(36)
  userId       String    @map("user_id") @db.VarChar(255)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  status       String    @default("attending") @db.VarChar(20)
  ticketNumber Int?      @map("ticket_number")
  tenantId     String?   @map("tenant_id") @db.VarChar

  @@map("event_attendees")
}

model EventCategories {
  id         Int       @id @default(autoincrement())
  name       String
  icon       String?   @default("calendar")
  orderIndex Int?      @default(0) @map("order_index")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId   String?   @map("tenant_id") @db.VarChar

  @@unique([name, tenantId])
  @@map("event_categories")
}

model EventEntries {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId           String    @map("event_id") @db.VarChar(36)
  userId            String    @map("user_id") @db.VarChar(36)
  teamName          String?   @map("team_name")
  playerNames       Json?     @default("[]") @map("player_names") @db.Json
  enteredAt         DateTime? @default(now()) @map("entered_at") @db.Timestamp(6)
  paymentStatus     String?   @default("pending") @map("payment_status")
  paymentAmount     String?   @map("payment_amount")
  signupType        String?   @default("team") @map("signup_type")
  playerCount       Int?      @default(1) @map("player_count")
  assignedPlayerIds Json?     @default("[]") @map("assigned_player_ids")
  score             Int?
  playerScores      Json?     @default("{}") @map("player_scores") @db.Json
  stripePaymentId   String?   @map("stripe_payment_id")
  playerHandicaps   Json?     @default("{}") @map("player_handicaps") @db.Json
  tenantId          String?   @map("tenant_id") @db.VarChar

  @@map("event_entries")
}

model EventSuggestions {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId          String    @map("user_id") @db.VarChar(255)
  name            String
  startDate       String    @map("start_date")
  endDate         String?   @map("end_date")
  venueName       String    @map("venue_name")
  address         String
  summary         String
  description     String
  imageUrl        String?   @map("image_url")
  tags            Json?     @default("[]") @db.Json
  ticketUrl       String?   @map("ticket_url")
  status          String    @default("pending")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamp(6)
  reviewedBy      String?   @map("reviewed_by") @db.VarChar(255)
  rejectionReason String?   @map("rejection_reason")
  groupEventId    String?   @map("group_event_id") @db.VarChar(36)
  approvedEventId String?   @map("approved_event_id") @db.VarChar(36)
  tenantId        String?   @map("tenant_id") @db.VarChar

  @@map("event_suggestions")
}

model Events {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  name                      String
  startDate                 String   @map("start_date")
  endDate                   String?  @map("end_date")
  venueName                 String   @map("venue_name")
  address                   String
  summary                   String
  description               String
  imageUrl                  String   @map("image_url")
  tags                      Json?    @default("[]") @db.Json
  ticketUrl                 String?  @map("ticket_url")
  isFeatured                Boolean? @default(false) @map("is_featured")
  slug                      String
  isEventGroup              Boolean? @default(false) @map("is_event_group")
  linkedGroupId             String?  @map("linked_group_id") @db.VarChar(36)
  isCarousel                Boolean? @default(false) @map("is_carousel")
  eventType                 String?  @default("standard") @map("event_type")
  maxEntries                Int?     @map("max_entries")
  teamSize                  Int?     @map("team_size")
  entryFee                  String?  @map("entry_fee")
  signupDeadline            String?  @map("signup_deadline")
  competitionFormat         String?  @map("competition_format")
  allowIndividualStableford Boolean? @default(false) @map("allow_individual_stableford")
  stripeProductId           String?  @map("stripe_product_id")
  stripePriceId             String?  @map("stripe_price_id")
  leagueTableSortOrder      String?  @default("highest_first") @map("league_table_sort_order")
  allowTeamHandicap         Boolean? @default(false) @map("allow_team_handicap")
  adminLastSeenEntrantCount Int?     @default(0) @map("admin_last_seen_entrant_count")
  tenantId                  String?  @map("tenant_id") @db.VarChar

  @@unique([slug, tenantId])
  @@map("events")
}

model GroupEventComments {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId         String    @map("event_id") @db.VarChar(36)
  userId          String    @map("user_id") @db.VarChar(255)
  parentCommentId String?   @map("parent_comment_id") @db.VarChar(36)
  content         String
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId        String?   @map("tenant_id") @db.VarChar

  @@map("group_event_comments")
}

model GroupEventReactions {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId      String  @map("event_id") @db.VarChar(36)
  userId       String  @map("user_id") @db.VarChar(255)
  reactionType String  @map("reaction_type")
  tenantId     String? @map("tenant_id") @db.VarChar

  @@map("group_event_reactions")
}

model GroupEvents {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  groupId      String    @map("group_id") @db.VarChar(36)
  userId       String    @map("user_id") @db.VarChar(255)
  name         String
  startDate    String    @map("start_date")
  endDate      String?   @map("end_date")
  venueName    String    @map("venue_name")
  address      String
  summary      String
  description  String
  imageUrl     String?   @map("image_url")
  tags         Json?     @default("[]") @db.Json
  ticketUrl    String?   @map("ticket_url")
  showOnPublic Boolean?  @default(false) @map("show_on_public")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId     String?   @map("tenant_id") @db.VarChar

  @@map("group_events")
}

model GroupMemberships {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  groupId     String    @map("group_id") @db.VarChar(36)
  userId      String    @map("user_id") @db.VarChar(255)
  role        String    @default("member")
  status      String    @default("pending")
  requestedAt DateTime? @default(now()) @map("requested_at") @db.Timestamp(6)
  approvedAt  DateTime? @map("approved_at") @db.Timestamp(6)
  approvedBy  String?   @map("approved_by") @db.VarChar(255)

  tenantId String? @map("tenant_id") @db.VarChar

  @@unique([groupId, userId], map: "group_member_unique")
  @@map("group_memberships")
}

model GroupPostComments {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  postId          String    @map("post_id") @db.VarChar(36)
  userId          String    @map("user_id") @db.VarChar(255)
  parentCommentId String?   @map("parent_comment_id") @db.VarChar(36)
  content         String
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId        String?   @map("tenant_id") @db.VarChar

  @@map("group_post_comments")
}

model GroupPostReactions {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  postId       String  @map("post_id") @db.VarChar(36)
  userId       String  @map("user_id") @db.VarChar(255)
  reactionType String  @map("reaction_type")
  tenantId     String? @map("tenant_id") @db.VarChar

  @@map("group_post_reactions")
}

model GroupPosts {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  groupId   String    @map("group_id") @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(255)
  content   String
  imageUrls Json?     @default("[]") @map("image_urls") @db.Json
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(6)
  edited    Boolean?  @default(false)
  category  String    @default("Social")
  postType  String    @default("post") @map("post_type")
  tenantId  String?   @map("tenant_id") @db.VarChar

  @@map("group_posts")
}

model Groups {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  name        String
  slug        String
  description String
  imageUrl    String?   @map("image_url")
  createdBy   String    @map("created_by") @db.VarChar(255)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  isActive    Boolean?  @default(true) @map("is_active")
  isPublic    Boolean?  @default(false) @map("is_public")
  eventId     String?   @map("event_id") @db.VarChar(36)
  tenantId    String?   @map("tenant_id") @db.VarChar

  @@unique([slug, tenantId])
  @@map("groups")
}

model HeroSettings {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  title    String
  subtitle String
  imageUrl String  @map("image_url")
  ctaText  String? @map("cta_text")
  ctaLink  String? @map("cta_link")
  tenantId String? @map("tenant_id") @db.VarChar

  @@map("hero_settings")
}

model InsiderTips {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  title    String
  tip      String
  author   String
  isActive Boolean? @default(true) @map("is_active")
  tenantId String?  @map("tenant_id") @db.VarChar

  @@map("insider_tips")
}

model MemberReviews {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId     String    @map("user_id") @db.VarChar(255)
  category   String
  placeName  String    @map("place_name")
  title      String
  summary    String
  liked      String
  disliked   String
  rating     Int
  imageUrl   String?   @map("image_url")
  status     String    @default("pending")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamp(6)
  reviewedBy String?   @map("reviewed_by") @db.VarChar(255)
  slug       String
  tenantId   String?   @map("tenant_id") @db.VarChar

  @@unique([slug, tenantId])
  @@map("member_reviews")
}

model Messages {
  id         Int       @id @default(autoincrement())
  senderId   String    @map("sender_id") @db.VarChar(255)
  receiverId String    @map("receiver_id") @db.VarChar(255)
  content    String
  isRead     Boolean?  @default(false) @map("is_read")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  tenantId   String?   @map("tenant_id") @db.VarChar

  @@map("messages")
}

model NewsletterSubscriptions {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  email        String
  subscribedAt String  @map("subscribed_at")
  tenantId     String? @map("tenant_id") @db.VarChar

  @@unique([email, tenantId])
  @@map("newsletter_subscriptions")
}

model PlayRequestCriteria {
